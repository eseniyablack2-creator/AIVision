# Скопируйте в .env только если нужен явный URL (без Vite-прокси).
# Для npm run dev:full строку можно не задавать — тогда используется /__aivision_inference → :8787.
#
# CT-скрининг и app.main (OpenAPI /docs) — порт 8787:
# VITE_PATHOLOGY_API_URL=http://127.0.0.1:8787
#
# Не подставляйте сюда :8000 — это другой процесс (api.main, 3D /v1/visualize из start-aivision.ps1).
# Для 3D при необходимости: VITE_SEGMENTATION_API_URL=http://127.0.0.1:8000
